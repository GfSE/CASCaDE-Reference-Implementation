# Cache-Control for all file types
# Cache expires in 1 day (86400 Sec)
# Applies rekursively to all subfolders
<IfModule mod_headers.c>
	# Cache-Control for 1 day
	Header set Cache-Control "public, max-age=86400"
</IfModule>
<IfModule mod_expires.c>
	# Aktivates Expires-Header
	ExpiresActive On
	# Expires: day
	ExpiresDefault "access plus 1 day"
</IfModule>
